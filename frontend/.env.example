# Frontend Environment Variables
# Copy to .env.local for local development
# Set in Vercel dashboard for production

# Backend API URL
# Development: leave empty (Vite proxy handles it)
# Production: MUST be set to your backend URL, e.g. https://your-backend.onrender.com
# Without this, API calls will fail in production!
VITE_API_URL=

# Enable Test Chat Tab (true for local, false for production)
VITE_ENABLE_TEST_CHAT=true
